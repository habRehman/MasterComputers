# ─── Copy these into Railway → Variables ───────────────────────────
# Do NOT commit the real .env to git

# MongoDB Atlas connection string
# Get from: Atlas Dashboard → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/master_computers?retryWrites=true&w=majority

# JWT — use a long random string, never share it
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Your Vercel frontend URL (no trailing slash)
# e.g. https://master-computers.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# ML service — only needed if you deploy ml_service separately
# Leave blank on Railway if ML service is not deployed
ML_SERVICE_URL=http://localhost:5001

NODE_ENV=production
